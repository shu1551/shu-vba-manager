# =============================================================================
# 個人設定・一時ファイル
# =============================================================================
# .claude/ 配下は個人設定なので除外。ただし配布スキルだけは公開する
.claude/*
!.claude/skills/
_last_proc.vba
__pycache__/
*.pyc
*.pyo
*.tmp
*.log

# =============================================================================
# バックアップ・作業履歴
# =============================================================================
backups/
作業ファイル/backups/
_wheel_dump/
*.backup_*
*.bak
*.bak_*

# checkup（健康診断）の出力・カルテ履歴（実行のたびに再生成される）
_last_checkup.md
作業ファイル/project/python_scripts/_checkup_history/

# =============================================================================
# 旧版 VBA バックアップ（ホイールフック等の廃止コード含む）
# =============================================================================
作業ファイル/*.vba

# =============================================================================
# .bas / .frm / .frx / .cls ソース
# 秀.xlsm 本体に同じコードが入っているため除外
# =============================================================================
作業ファイル/project/python_scripts/*.bas
作業ファイル/project/python_scripts/*.frm
作業ファイル/project/python_scripts/*.frx
作業ファイル/project/python_scripts/*.cls
作業ファイル/project/python_scripts/*.vba

# =============================================================================
# Python 作業履歴（過去のワンショットスクリプト多数）
# README で紹介している主要ツールのみホワイトリストで公開
# =============================================================================
作業ファイル/project/python_scripts/*.py
