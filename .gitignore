# =============================================================================
# 個人設定・一時ファイル
# =============================================================================
# .claude/ 配下は個人設定なので除外。ただし配布スキルだけは公開する
.claude/*
!.claude/skills/
_last_proc.vba
__pycache__/
*.pyc
*.pyo
*.tmp
*.log

# =============================================================================
# バックアップ・作業履歴
# =============================================================================
backups/
作業ファイル/backups/
_wheel_dump/
*.backup_*
*.bak

# =============================================================================
# 旧版 VBA バックアップ（ホイールフック等の廃止コード含む）
# =============================================================================
作業ファイル/*.vba

# =============================================================================
# .bas / .frm / .frx / .cls ソース
# 秀.xlsm 本体に同じコードが入っているため除外
# =============================================================================
作業ファイル/project/python_scripts/*.bas
作業ファイル/project/python_scripts/*.frm
作業ファイル/project/python_scripts/*.frx
作業ファイル/project/python_scripts/*.cls
作業ファイル/project/python_scripts/*.vba

# =============================================================================
# Python 作業履歴（過去のワンショットスクリプト多数）
# README で紹介している主要ツールのみホワイトリストで公開
# =============================================================================
作業ファイル/project/python_scripts/*.py
!作業ファイル/project/python_scripts/vba_manager.py
!作業ファイル/project/python_scripts/form_builder.py
!作業ファイル/project/python_scripts/live_sync_vba.py
!作業ファイル/project/python_scripts/menu_launcher.py
!作業ファイル/project/python_scripts/select_macro_gui.py
!作業ファイル/project/python_scripts/bas_editor.py
!作業ファイル/project/python_scripts/format_bas.py
!作業ファイル/project/python_scripts/optimize_vba_modules.py
